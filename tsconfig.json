{
  "compilerOptions": {
    "target": "es2022",                                
    "module": "commonjs",                                
    "rootDir": "./backend//src",    
    "outDir": "./backend/dist",                             
    "esModuleInterop": true,                             
    "forceConsistentCasingInFileNames": true,            
    "strict": true,                                    
    "skipLibCheck": true                                
  },
  "include": [
    "backend/src/**/*",
  ],
    "exclude": [
    "node_modules", 
    "**/*.test.ts", 
  ]
}